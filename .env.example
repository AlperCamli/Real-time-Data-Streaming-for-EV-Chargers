APP_ENV=local
LOG_LEVEL=INFO
LOG_JSON=false
METRICS_ENABLED=true
METRICS_HOST=0.0.0.0
PROCESSOR_METRICS_PORT=9100
SIMULATOR_METRICS_PORT=9200

KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_RAW=cs.ev.events.raw
KAFKA_TOPIC_DLQ=cs.ev.events.dlq
KAFKA_TOPIC_LATE=cs.ev.events.late
KAFKA_CONSUMER_GROUP=cs-processor

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
DEDUP_TTL_SECONDS=86400

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=password
CLICKHOUSE_DATABASE=default

PROCESSOR_CONFIG_PATH=config/processor.default.yaml
SIMULATOR_CONFIG_PATH=config/simulator.default.yaml
